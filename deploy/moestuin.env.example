MOESTUIN_BIND=127.0.0.1:8080
MOESTUIN_DATABASE_URL=sqlite:/var/lib/moestuin/moestuin.db
MOESTUIN_ALLOWED_EMAILS=you@example.com,family@example.com
MOESTUIN_MOCK_HW=0
# MOESTUIN_WEBCAM_ROOT=/data/webcam   # default; override only if you remap the volume

# Google OIDC
MOESTUIN_OIDC_CLIENT_ID=
MOESTUIN_OIDC_CLIENT_SECRET=
MOESTUIN_OIDC_REDIRECT=https://moestuin.example.com/auth/callback

# Session cookie signing key — 32+ random bytes, base64
MOESTUIN_SESSION_KEY=

RUST_LOG=info
